# Cloudflare Pages headers — long cache on static assets, short on HTML.
# HTML must revalidate so deploys propagate instantly.
#
# Phase C7 cutover layout:
#   /admin/dcr/         → React app  (primary)
#   /admin/dcr-legacy/  → Legacy vanilla console (fallback)

/*.html
  Cache-Control: public, max-age=0, must-revalidate

# ── Legacy vanilla console at /admin/dcr-legacy/ ────────────────────────
/admin/dcr-legacy/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Hashable static assets — safe to cache for a year (filenames change on
# every meaningful edit).
/admin/dcr-legacy/js/*
  Cache-Control: public, max-age=31536000, must-revalidate

/admin/dcr-legacy/css/*
  Cache-Control: public, max-age=31536000, must-revalidate

/admin/dcr-legacy/img/*
  Cache-Control: public, max-age=31536000, immutable

# ── React app at /admin/dcr/ ────────────────────────────────────────────
# Vite hashes JS/CSS under /admin/dcr/assets/* — cache forever.
/admin/dcr/assets/*
  Cache-Control: public, max-age=31536000, immutable

/admin/dcr/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/admin/dcr/img/*
  Cache-Control: public, max-age=31536000, immutable

# The shell HTML must revalidate so users pick up new builds immediately.
/admin/dcr/index.html
  Cache-Control: public, max-age=0, must-revalidate

/admin/dcr/
  Cache-Control: public, max-age=0, must-revalidate
